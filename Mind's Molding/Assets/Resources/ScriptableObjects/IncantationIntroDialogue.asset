  m_Script: {fileID: 11500000, guid: d0a663575cba5a64886a6bdb08734bb7, type: 3}
  m_Name: IncantationIntroDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  speakerName: Whim
  lines:
  - '"Now you''re probably still curious about that book."'
  - "\u201CThat\u2019s a grimoire! A book about magic. This one\u2019s about cooking,
    specifically, but there should be enough in there for you to put together your
    very own incantation!\u201D"
  - "\u201CThe simplest incantations have three parts: the subject, the effect, and
    the target. The subject describes what something is happening to. The effect
    describes what\u2019s happening. The target describes where it\u2019s happening.\u201D"
  - "\u201CPick and choose the pieces for the spell you need!\u201D"
  - '"Go check out the incantation table once you''ve figured out the spell that
    will help rid you of this infection." '
  triggerKey: Book
  nextNode: {fileID: 0}
  onComplete:
    m_PersistentCalls:
      m_Calls: []
  typingSpeed: 0.05
  autoProgressDelay: 1.5
